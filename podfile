  # Pods for the APP
  pod 'SwiftyJSON'
  pod 'Realm'

  pod 'Braintree'
  pod 'BraintreeDropIn'

  pod 'FirebaseAuth'
  pod 'FirebaseFirestore'
  pod 'FirebaseMessaging'
  pod 'Starscream'

  # Test target inherits everything
  target 'SwiftCinemasTests' do
    inherit! :complete
  end

end